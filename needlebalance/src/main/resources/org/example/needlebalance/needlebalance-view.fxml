<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<AnchorPane fx:id="scene" style="-fx-background-color: linear-gradient(to bottom, #87ceeb, #d7f4ff);" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.needlebalance.NBController">

    <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <VBox alignment="CENTER" spacing="18">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <Label style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #243447;" text="Rock Balance!" />

            <Label fx:id="statusLabel" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #243447;" text="Press START, then use ← and → to balance." />

            <Label fx:id="rockLabel" style="-fx-font-size: 16px; -fx-text-fill: #243447;" text="Rock: 1" />

            <!-- Game stage -->
            <Pane fx:id="gamePane" maxWidth="620" minWidth="620" prefHeight="310" prefWidth="620" style="-fx-background-color: linear-gradient(to bottom, transparent 0%, transparent 62%, #3f9fd9 63%, #1c6f9c 100%);                          -fx-background-radius: 20;                          -fx-border-color: rgba(255,255,255,0.7);                          -fx-border-radius: 20;                          -fx-border-width: 2;">

                <!-- Water highlights -->
                <Line endX="170" endY="245" startX="40" startY="245" style="-fx-stroke: rgba(255,255,255,0.45); -fx-stroke-width: 3;" />
                <Line endX="570" endY="270" startX="420" startY="270" style="-fx-stroke: rgba(255,255,255,0.35); -fx-stroke-width: 3;" />

                <!-- Rock group: controller rotates this -->
                <Group fx:id="rockGroup" layoutX="310" layoutY="215">
                    <Ellipse fx:id="rock" centerX="0" centerY="25" radiusX="92" radiusY="34" style="-fx-fill: #6d6257; -fx-stroke: #3f3933; -fx-stroke-width: 3;" />
                    <Ellipse centerX="-25" centerY="10" radiusX="38" radiusY="16" style="-fx-fill: rgba(255,255,255,0.12);" />
                </Group>

                <!-- Player group: controller rotates and moves this -->
                <Group fx:id="playerGroup" layoutX="310" layoutY="185">
                    <!-- legs -->
                    <Line endX="-24" endY="36" startX="0" startY="0" style="-fx-stroke: #202020; -fx-stroke-width: 5; -fx-stroke-line-cap: round;" />
                    <Line endX="24" endY="36" startX="0" startY="0" style="-fx-stroke: #202020; -fx-stroke-width: 5; -fx-stroke-line-cap: round;" />

                    <!-- body -->
                    <Line endX="0" endY="-55" startX="0" startY="0" style="-fx-stroke: #202020; -fx-stroke-width: 6; -fx-stroke-line-cap: round;" />

                    <!-- arms -->
                    <Line endX="-38" endY="-15" startX="0" startY="-35" style="-fx-stroke: #202020; -fx-stroke-width: 5; -fx-stroke-line-cap: round;" />
                    <Line endX="38" endY="-15" startX="0" startY="-35" style="-fx-stroke: #202020; -fx-stroke-width: 5; -fx-stroke-line-cap: round;" />

                    <!-- head -->
                    <Circle centerX="0" centerY="-75" radius="16" style="-fx-fill: #ffd19c; -fx-stroke: #202020; -fx-stroke-width: 3;" />
                </Group>

                <!-- Danger indicators -->
                <Label fx:id="fallWarningLabel" layoutX="190" layoutY="25" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #b00020;" text="" />
            </Pane>

            <!-- Balance Bar -->
            <Pane fx:id="balancePane" maxWidth="500" minWidth="500" prefHeight="58" prefWidth="500">

                <Rectangle fx:id="backgroundBar" arcHeight="12" arcWidth="12" height="22" style="-fx-fill: #3a3a3a;" width="500" x="0" y="18" />

                <Rectangle fx:id="dangerLeft" arcHeight="12" arcWidth="12" height="22" style="-fx-fill: #c62828;" width="90" x="0" y="18" />

                <Rectangle fx:id="dangerRight" arcHeight="12" arcWidth="12" height="22" style="-fx-fill: #c62828;" width="90" x="410" y="18" />

                <Rectangle fx:id="safeZone" arcHeight="12" arcWidth="12" height="22" style="-fx-fill: limegreen;" width="80" x="210" y="18" />

                <Line fx:id="balanceMarker" endX="250" endY="55" startX="250" startY="3" style="-fx-stroke: white; -fx-stroke-width: 5;" />

            </Pane>

            <ProgressBar fx:id="scoreProgressBar" prefWidth="500" progress="0" />

            <Label fx:id="scoreLabel" style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Stability: 0%" />

            <Button fx:id="startButton" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 8 20 8 20;" text="START" />

        </VBox>

    </StackPane>

</AnchorPane>
