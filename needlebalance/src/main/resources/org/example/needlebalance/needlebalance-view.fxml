<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<AnchorPane fx:id="scene" style="-fx-background-color: #0f1117;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.needlebalance.NBController">

    <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <VBox alignment="CENTER" spacing="18">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>
            <Label style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #f5f7fa;" text="Balance on the Rock" />

            <Label fx:id="statusLabel" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #d7dde8;" text="Press ENTER, then use ← and → to balance." />

            <Label fx:id="rockLabel" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #d7dde8;" text="Rock: 1" />

            <!-- Game stage -->
            <Pane fx:id="gamePane" maxWidth="620" minWidth="620" prefHeight="310" prefWidth="620" style="-fx-background-color: #111827; -fx-background-radius: 20; -fx-border-color: #e5e7eb; -fx-border-radius: 10; -fx-border-width: 2;">

                <ImageView fitHeight="449.0" fitWidth="667.0" layoutX="-24.0" layoutY="-9.0" preserveRatio="true">
                    <image>
                        <Image url="@images/raging_river.png" />
                    </image>
                </ImageView>

                <!-- Rock group: controller rotates this -->
                <Group fx:id="rockGroup" layoutX="310" layoutY="300.0">
                    <ImageView fitHeight="127.0" fitWidth="220.0" layoutX="-110.0" layoutY="-20.0" preserveRatio="true">
                        <image>
                            <Image url="@images/rock.png" />
                        </image>
                  <effect>
                     <Lighting bumpInput="$null" diffuseConstant="2.0" specularConstant="0.0" surfaceScale="0.0">
                        <light>
                           <Light.Distant />
                        </light>
                     </Lighting>
                  </effect>
                    </ImageView>
                </Group>

                <!-- Player group: controller rotates and moves this -->
                <Group fx:id="playerGroup" layoutX="310" layoutY="300.0">
                    <ImageView fitHeight="257.0" fitWidth="400.0" layoutX="-200.0" layoutY="-200.0" preserveRatio="true">
                        <image>
                            <Image url="@images/major_front_transparent.png" />
                        </image>
                    </ImageView>
                </Group>


                <!-- Danger indicators -->
                <Label fx:id="fallWarningLabel" layoutX="190" layoutY="25" prefWidth="5.0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #b00020;" text="" />

            </Pane>

            <!-- Balance Bar -->
            <Pane fx:id="balancePane" maxWidth="500" minWidth="500" prefHeight="58" prefWidth="500">

                <Rectangle fx:id="backgroundBar" arcHeight="12" arcWidth="12" height="22" style="-fx-fill: #3a3a3a;" width="500" x="0" y="18" />

                <Rectangle fx:id="dangerLeft" arcHeight="12" arcWidth="12" height="22" style="-fx-fill: #c62828;" width="90" x="0" y="18" />

                <Rectangle fx:id="dangerRight" arcHeight="12" arcWidth="12" height="22" style="-fx-fill: #c62828;" width="90" x="410" y="18" />

                <Rectangle fx:id="safeZone" arcHeight="12" arcWidth="12" height="22" style="-fx-fill: limegreen;" width="80" x="210" y="18" />

                <Line fx:id="balanceMarker" endX="250" endY="55" startX="250" startY="3" stroke="#0026ff" style="-fx-stroke: #800202; -fx-stroke-width: 5;" />

            </Pane>

            <ProgressBar fx:id="scoreProgressBar" prefWidth="500" progress="0" />

            <Label fx:id="scoreLabel" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #d7dde8;" text="Stability: 0%" />

            <Button fx:id="startButton" style="-fx-background-color: #2563eb; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 8 22 8 22; -fx-cursor: hand;" text="START" />

        </VBox>

    </StackPane>
</AnchorPane>
